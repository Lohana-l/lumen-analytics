# =============================================================================
# Cairn Analytics - variables d'environnement.
# -----------------------------------------------------------------------------
# Copier ce fichier en `.env` (gitignoré) : docker-compose et les CLI Python
# le chargent automatiquement.
#
# IMPORTANT - identifiants de DEV LOCAL uniquement.
# Les valeurs ci-dessous (cairn / password / admin) sont des identifiants
# jetables pour une stack 100 % locale sur votre machine. Ce ne sont PAS des
# secrets de production : aucune donnée réelle, aucun service exposé sur
# Internet. En production, ces valeurs seraient injectées par un gestionnaire
# de secrets (Vault, AWS Secrets Manager, variables d'environnement CI/CD) et
# jamais commitées. docker-compose lit chaque valeur via ${VAR:-defaut}, donc
# `make up` fonctionne sans configuration, et tout override passe par ce .env.
# =============================================================================

# -- Postgres -----------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=cairn
POSTGRES_PASSWORD=password
POSTGRES_DB=cairn

# Utilisé par les exécutions Python locales (hors compose) :
DB_URI=postgresql://cairn:password@localhost:5532/cairn

# -- Grafana (profil obs) -----------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# -- MLflow -------------------------------------------------------------------
MLFLOW_TRACKING_URI=http://mlflow:5000

# -- ML model bundle location -------------------------------------------------
CAIRN_MODEL_DIR=./ml/models

# -- Prefect ------------------------------------------------------------------
PREFECT_API_URL=http://localhost:4200/api   # local (hors Docker)
# PREFECT_API_URL=http://prefect:4200/api  # dans Docker (déjà injecté par compose)

# -- Prometheus ---------------------------------------------------------------
PROMETHEUS_URL=http://localhost:9090        # local (hors Docker)
# PROMETHEUS_URL=http://prometheus:9090     # dans Docker (déjà injecté par compose)

# -- Reporting date (used by dbt vars + ml.features as-of window) -------------
CAIRN_REPORTING_DATE=2026-04-01
